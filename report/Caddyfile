# Caddyfile — Reverse proxy for NJ Reparations Council Report MCP
#
# Caddy handles:
#   - TLS termination (auto HTTPS via Let's Encrypt if you set a real domain)
#   - Request logging
#   - Proxying to the MCP app and dashboard
#
# For Raspberry Pi / local dev, it runs on :80 (no TLS).
# Set CADDY_DOMAIN env var to enable auto-HTTPS for production.

{
	# Global options
	admin off
}

# Use domain from env, fallback to :80 for local/Pi
{$CADDY_DOMAIN::80}

# Health check (bypass proxy)
handle /health {
	respond "OK" 200
}

# Reports dashboard — served from the sidecar
handle /reporting* {
	reverse_proxy dashboard:8050
}

# MCP server — everything else
handle {
	reverse_proxy mcp:8080 {
		# Pass through headers for session tracking
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}

		# Flush for SSE / streaming MCP transport
		flush_interval -1
	}
}

# Access logging
log {
	output stdout
	format json
}
